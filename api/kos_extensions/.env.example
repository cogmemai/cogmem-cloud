# cogmem-kos-acs Cloud Configuration
# Copy this file to .env and fill in your values

# SurrealDB (unified backing store)
SURREALDB_URL=ws://localhost:8001
SURREALDB_NAMESPACE=cogmem
SURREALDB_DATABASE=kos
SURREALDB_USER=root
SURREALDB_PASSWORD=root

# LLM Gateway (via LiteLLM)
LITELLM_API_BASE=http://localhost:4000
LITELLM_API_KEY=
LITELLM_DEFAULT_MODEL=gpt-4o-mini

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
