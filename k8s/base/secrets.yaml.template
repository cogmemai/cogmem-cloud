# IMPORTANT: This is a template file. 
# Copy this to secrets.yaml and replace all values with base64-encoded secrets.
# To encode: echo -n "your-secret-value" | base64
# DO NOT commit secrets.yaml to git! Add it to .gitignore

apiVersion: v1
kind: Secret
metadata:
  name: cogmem-secrets
  namespace: cogmem
type: Opaque
data:
  # Database passwords (base64 encoded)
  postgres-password: <BASE64_ENCODED_PASSWORD>
  neo4j-password: <BASE64_ENCODED_PASSWORD>
  qdrant-api-key: <BASE64_ENCODED_API_KEY>
  surreal-password: <BASE64_ENCODED_PASSWORD>
  
  # Application secrets (base64 encoded)
  secret-key: <BASE64_ENCODED_SECRET_KEY>
  first-superuser-password: <BASE64_ENCODED_PASSWORD>
  
  # SMTP (base64 encoded, optional)
  smtp-password: <BASE64_ENCODED_PASSWORD>
  
  # Sentry DSN (base64 encoded, optional)
  sentry-dsn: <BASE64_ENCODED_DSN>
  
  # OpenRouter API key (base64 encoded)
  openrouter-api-key: <BASE64_ENCODED_API_KEY>

  # GitHub PAT for OpenClaw autonomous commits (base64 encoded, optional)
  github-pat: <BASE64_ENCODED_GITHUB_PAT>
